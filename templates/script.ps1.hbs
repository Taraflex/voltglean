Set-StrictMode -Version 1
$ErrorActionPreference = 'Stop'
[Console]::OutputEncoding = [Text.Encoding]::UTF8

if (!([System.Security.Principal.WindowsPrincipal][System.Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([System.Security.Principal.WindowsBuiltInRole]::Administrator)) {
  $rawArgs = [Environment]::GetCommandLineArgs() | Select-Object -Skip 1
  $scriptPath = $MyInvocation.MyCommand.Path

  $pwshArgs = @('-NoExit') 
  $scriptArgs = @()  
  $foundScriptPath = $false
  $skipNext = $false

  foreach ($arg in $rawArgs) {
    if ($skipNext) {
      $skipNext = $false
      continue
    }

    if (!$foundScriptPath) {
      $resolvedPath = Resolve-Path -LiteralPath $arg -ErrorAction SilentlyContinue
      if ($resolvedPath -and $resolvedPath.Path -eq $scriptPath) {
        $foundScriptPath = $true
        continue
      }

      if ($arg -match '^-(ExecutionPolicy|ep)$') {
        $skipNext = $true; continue 
      }
      if ($arg -match '^-(NoExit|noe|File|f)$') {
        continue 
      }

      $pwshArgs += $arg
    }
    else {
      $scriptArgs += $arg
    }
  }

  $finalArguments = $pwshArgs + @(
    '-ExecutionPolicy', 'Bypass', '-File', $scriptPath    
  ) + $scriptArgs

  Start-Process (Get-Process -Id $PID).Path -Verb RunAs -ArgumentList $finalArguments
  [Environment]::Exit(740)
}
{% for (guid, plan) in plans %}
# ============================================================================
#region PLAN: {{ plan.description }} ({{ guid }})
# ============================================================================
  {%- let p_id = plan.alias.as_ref().unwrap_or(guid) %}
  {% for (s_guid, sub) in plan.subgroups %}
  #region {{ sub.description }} ({{ s_guid }})
    {%- let s_id = sub.alias.as_ref().unwrap_or(s_guid) %}
    {% for (st_guid, setting) in sub.settings %}
    # {{ setting.description }} | {{ setting.options|format_opts }}
    powercfg /setacvalueindex {{ p_id }} {{ s_id }} {{ setting.alias.as_ref().unwrap_or(st_guid) }} {{ setting.ac }} #🔌
    powercfg /setdcvalueindex {{ p_id }} {{ s_id }} {{ setting.alias.as_ref().unwrap_or(st_guid) }} {{ setting.dc }} #🔋
    {% endfor %}
  #endregion
  {%- endfor %}
#endregion
{%- endfor %}
{%- if let Some(active) = active_plan %}
# ============================================================================
powercfg /setactive {{ active }}
{% endif %}
Write-Host `a # beep